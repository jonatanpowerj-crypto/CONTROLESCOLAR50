rules_version = '2';
// ════════════════════════════════════════════════════════════════
// REGLAS DE SEGURIDAD — SIGE Prepa 50 (Firestore)
// Cópialo y pégalo en: Firestore → pestaña Reglas → Publicar
//
// NIVEL ACTUAL (sin costo, plan Spark):
//   - Consulta pública para el portal de padres/alumnos.
//   - Escritura solo para usuarios con sesión iniciada.
//   - La separación POR DOCENTE (cada quien gestiona solo sus
//     materias) se aplica en la INTERFAZ (app.js / nube.js): el
//     sistema oculta y filtra todo lo que no le corresponde.
//
//   Para una preparatoria con docentes de confianza esto es
//   suficiente; la interfaz evita errores accidentales y el respaldo
//   protege ante cualquier problema.
//
// NIVEL BLINDADO (requiere plan Blaze + Cloud Functions):
//   Para impedir por completo que un docente escriba fuera de sus
//   materias, se graba el rol en el token ("custom claims") con una
//   Cloud Function y se valida aqui. Pide a tu desarrollador activar
//   Blaze y desplegar esa funcion cuando el plantel lo decida.
// ════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {
    match /{coleccion}/{documento=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
