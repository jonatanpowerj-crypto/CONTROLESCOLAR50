rules_version = '2';
// ════════════════════════════════════════════════════════════════
// REGLAS DE SEGURIDAD — SIGE Prepa 50 (Firestore)
// Copia TODO este archivo y pégalo en:
// Consola de Firebase → Firestore Database → Reglas → Publicar
//
// OPCIÓN A (activa): lectura pública, escritura solo con sesión.
//   ✔ Los padres y alumnos consultan desde casa SIN cuenta.
//   ✔ Solo los docentes con sesión iniciada pueden modificar.
//   ⚠ Cualquier persona con la dirección del sitio puede LEER los
//     datos (nombres, asistencias, calificaciones). Valórenlo como
//     plantel por tratarse de datos de menores.
//
// OPCIÓN B (comentada): todo privado, se requiere sesión también
//   para leer. El portal de padres solo funcionaría con una cuenta
//   compartida de consulta que cree la dirección.
// ════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {
    match /{coleccion}/{documento=**} {

      // ── OPCIÓN A (recomendada para empezar) ──
      allow read:  if true;
      allow write: if request.auth != null;

      // ── OPCIÓN B (todo privado): borra las dos líneas de arriba
      //    y quita las diagonales // de las dos líneas siguientes ──
      // allow read:  if request.auth != null;
      // allow write: if request.auth != null;
    }
  }
}
